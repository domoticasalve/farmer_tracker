# --- Base de datos ---
POSTGRES_DB=farmer_tracker
POSTGRES_USER=farmer
POSTGRES_PASSWORD=changeme_strong_password

# URL interna Docker (no cambiar el host si usas docker-compose)
DATABASE_URL=postgresql://farmer:changeme_strong_password@postgres:5432/farmer_tracker

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth JWT ---
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- App ---
ENVIRONMENT=production
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# --- CORS (dominio donde se despliega la app) ---
CORS_ORIGIN=http://tusubdominio.tudominio.com
